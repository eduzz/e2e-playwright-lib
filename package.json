{
  "name": "@eduzz/e2e-playwright-base",
  "version": "0.5.0",
  "private": false,
  "description": "Base project for playwright tests",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/reporters/DiscordReporter": {
      "types": "./dist/reporters/DiscordReporter.d.ts",
      "import": "./dist/reporters/DiscordReporter.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "tsc",
    "lint": "eslint",
    "prepublishOnly": "tsc"
  },
  "keywords": [
    "eduzz",
    "playwright",
    "e2e"
  ],
  "author": "Eduzz Team",
  "license": "MIT",
  "homepage": "https://github.com/eduzz/e2e-playwright-base",
  "repository": {
    "type": "git",
    "url": "https://github.com/eduzz/e2e-playwright-base"
  },
  "bugs": {
    "url": "https://github.com/eduzz/e2e-playwright-base/issues"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "dotenv": "^17.4.2",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.50.0"
  },
  "devDependencies": {
    "@eduzz/eslint-config": "3.0.0",
    "@playwright/test": "1.61.0",
    "@reportportal/agent-js-playwright": "5.4.1",
    "@types/node": "25.9.3",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "playwright-json-summary-reporter": "1.0.1",
    "typescript": "6.0.3"
  }
}
